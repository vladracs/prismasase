{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
        "srcIPInboundNSG": { "type": "string", "defaultValue": "0.0.0.0/0" },
        "imageVersion": { "type": "string", "allowedValues": [ "latest", "5.6.3", "5.5.3" ], "defaultValue": "latest" },
        "vmSize": { "type": "string", "allowedValues": [ "Standard_D8s_v3" ], "defaultValue": "Standard_D8s_v3" },
        "virtualNetworkName": { "type": "string", "defaultValue": "CGNXVNET" },
        "vnetNewOrExisting": { "type": "string", "defaultValue": "new", "allowedValues": [ "new", "existing" ] },
        "virtualNetworkAddressPrefixes": { "type": "array", "defaultValue": "[array('10.5.0.0/16')]" },
        "virtualNetworkExistingRGName": { "type": "string", "defaultValue": "" },
        "subnet0Name": { "type": "string", "defaultValue": "Controller" },
        "subnet1Name": { "type": "string", "defaultValue": "Internet-1" },
        "subnet2Name": { "type": "string", "defaultValue": "LAN" },
        "subnet3Name": { "type": "string", "defaultValue": "Internet-2" },
        "subnet0Prefix": { "type": "string", "defaultValue": "10.5.0.0/24" },
        "subnet1Prefix": { "type": "string", "defaultValue": "10.5.1.0/24" },
        "subnet2Prefix": { "type": "string", "defaultValue": "10.5.2.0/24" },
        "subnet3Prefix": { "type": "string", "defaultValue": "10.5.3.0/24" },
        "publicIPNewOrExisting": { "type": "string", "defaultValue": "new", "allowedValues": [ "new", "existing" ] },
        "publicIPRGName": { "type": "string", "defaultValue": "" },
        "publicIPAddressName": { "type": "string", "defaultValue": "vioncntlr" },
        "publicIPAllocationMethod": { "type": "string", "defaultValue": "Static", "allowedValues": [ "Dynamic", "Static" ] },
        "intPortPrivateIP": { "type": "string", "defaultValue": "10.5.1.10" },
        "intPortGateway": { "type": "string", "defaultValue": "10.5.1.1" },
        "intPortDns": { "type": "string", "defaultValue": "8.8.8.8" },
        "bootstrap": { "type": "string", "defaultValue": "yes", "allowedValues": [ "yes" ] },
        "licenseKey": { "type": "securestring" },
        "secretKey": { "type": "securestring" },
        "zone": { "type": "string", "defaultValue": "None" },
        "availabilitySetName": { "type": "string", "defaultValue": "None" },
        "availabilitySetPlatformFaultDomainCount": { "type": "string", "defaultValue": "2" },
        "availabilitySetPlatformUpdateDomainCount": { "type": "string", "defaultValue": "2" },
        "adminUser": { "type": "string", "defaultValue": "adminuser" },
        "adminPass": { "type": "securestring" }
    },
    "variables": {
        "imagePublisher": "paloaltonetworks",
        "imageSku": "prisma-sdwan-ion-virtual-appliance",
        "imageOffer": "prisma-sd-wan-ion-virtual-appliance",
        "vmName": "[concat('Prisma-SD-WAN-vION','-',parameters('location'))]",
        "nsgName": "DefaultIONNSG",
        "nicName": "[concat(variables('vmName'), '-eth')]",
        
        "existingVnetID": "[resourceId(parameters('virtualNetworkExistingRGName'),concat('Microsoft.Network','/','virtualNetworks'),parameters('virtualNetworkName'))]",
        "newVnetID": "[resourceId('Microsoft.Network/virtualNetworks',parameters('virtualNetworkName'))]",
        
        "existingSubnet0Ref": "[concat(variables('existingVnetID'),'/subnets/',parameters('subnet0Name'))]",
        "newSubnet0Ref": "[concat(variables('newVnetID'),'/subnets/',parameters('subnet0Name'))]",
        "subnet0Ref": "[if(equals(parameters('vnetNewOrExisting'),'new'), variables('newSubnet0Ref'), variables('existingSubnet0Ref'))]",
        
        "existingSubnet1Ref": "[concat(variables('existingVnetID'),'/subnets/',parameters('subnet1Name'))]",
        "newSubnet1Ref": "[concat(variables('newVnetID'),'/subnets/',parameters('subnet1Name'))]",
        "subnet1Ref": "[if(equals(parameters('vnetNewOrExisting'),'new'), variables('newSubnet1Ref'), variables('existingSubnet1Ref'))]",
        
        "existingSubnet2Ref": "[concat(variables('existingVnetID'),'/subnets/',parameters('subnet2Name'))]",
        "newSubnet2Ref": "[concat(variables('newVnetID'),'/subnets/',parameters('subnet2Name'))]",
        "subnet2Ref": "[if(equals(parameters('vnetNewOrExisting'),'new'), variables('newSubnet2Ref'), variables('existingSubnet2Ref'))]",

        "existingSubnet3Ref": "[concat(variables('existingVnetID'),'/subnets/',parameters('subnet3Name'))]",
        "newSubnet3Ref": "[concat(variables('newVnetID'),'/subnets/',parameters('subnet3Name'))]",
        "subnet3Ref": "[if(equals(parameters('vnetNewOrExisting'),'new'), variables('newSubnet3Ref'), variables('existingSubnet3Ref'))]",

        "virtualNetworkAddressPrefix": "[parameters('virtualNetworkAddressPrefixes')[0]]",
        "nic1PrefixLen": "[split(parameters('subnet1Prefix'), '/')[1]]",
        "customData": "[base64(concat('[General]\nmodel = ion 7108v\nhost1_name = locator.cgnx.net\n\n[License]\nkey = ',parameters('licenseKey'),'\nsecret = ',parameters('secretKey'),'\n\n[Controller 1]\ntype = DHCP\n\n[1]\nrole = PublicWAN\ntype = STATIC\naddress = ',parameters('intPortPrivateIP'),'/',variables('nic1PrefixLen'),'\ngateway = ',parameters('intPortGateway'),'\ndns1 = ', parameters('intPortDns')))]",
        
        "nic0": "[concat(variables('nicName'), '0')]",
        "nic1": "[concat(variables('nicName'), '1')]",
        "nic2": "[concat(variables('nicName'), '2')]",
        "nic3": "[concat(variables('nicName'), '3')]",
        "zones": [ "[parameters('zone')]" ],
        "availabilitySet": { "id": "[resourceId('Microsoft.Compute/availabilitySets', parameters('availabilitySetName'))]" },
        "subnets": [
            { "name": "[parameters('subnet0Name')]", "properties": { "addressPrefix": "[parameters('subnet0Prefix')]" } },
            { "name": "[parameters('subnet1Name')]", "properties": { "addressPrefix": "[parameters('subnet1Prefix')]", "networkSecurityGroup": { "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]" } } },
            { "name": "[parameters('subnet2Name')]", "properties": { "addressPrefix": "[parameters('subnet2Prefix')]" } },
            { "name": "[parameters('subnet3Name')]", "properties": { "addressPrefix": "[parameters('subnet3Prefix')]", "networkSecurityGroup": { "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]" } } }
        ]
    },
    "resources": [
        {
            "name": "extraNicPublicIP",
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2021-01-01",
            "location": "[parameters('location')]",
            "sku": { "name": "Standard", "tier": "Regional" },
            "properties": { "publicIPAddressVersion": "IPv4", "publicIPAllocationMethod": "Static", "idleTimeoutInMinutes": 4 }
        },
        {
            "name": "[parameters('publicIPAddressName')]",
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2021-01-01",
            "condition": "[equals(parameters('publicIPNewOrExisting'), 'new')]",
            "location": "[parameters('location')]",
            "sku": { "name": "Standard", "tier": "Regional" },
            "properties": { "publicIPAddressVersion": "IPv4", "publicIPAllocationMethod": "[parameters('publicIPAllocationMethod')]", "idleTimeoutInMinutes": 4, "ipTags": [] }
        },
        {
            "name": "[variables('nsgName')]",
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2021-01-01",
            "location": "[parameters('location')]",
            "properties": {
                "securityRules": [
                    { "name": "IkeRule", "properties": { "protocol": "Udp", "sourcePortRange": "*", "sourceAddressPrefix": "*", "destinationPortRange": "500", "destinationAddressPrefix": "*", "access": "Allow", "priority": 2064, "direction": "Inbound" } },
                    { "name": "NatRule", "properties": { "protocol": "Udp", "sourcePortRange": "*", "sourceAddressPrefix": "*", "destinationPortRange": "4500", "destinationAddressPrefix": "*", "access": "Allow", "priority": 2080, "direction": "Inbound" } }
                ]
            }
        },
        {
            "name": "[parameters('virtualNetworkName')]",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2021-01-01",
            "condition": "[equals(parameters('vnetNewOrExisting'), 'new')]",
            "dependsOn": [ "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]" ],
            "location": "[parameters('location')]",
            "properties": { "addressSpace": { "addressPrefixes": [ "[variables('virtualNetworkAddressPrefix')]" ] }, "subnets": "[variables('subnets')]" }
        },
        {
            "name": "[variables('nic0')]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2021-01-01",
            "dependsOn": [ "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]" ],
            "location": "[parameters('location')]",
            "properties": {
                "ipConfigurations": [ { "name": "ipconfig-mgmt", "properties": { "privateIPAllocationMethod": "Dynamic", "subnet": { "id": "[variables('subnet0Ref')]" } } } ]
            }
        },
        {
            "name": "[variables('nic1')]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2021-01-01",
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]",
                "[concat('Microsoft.Network/publicIPAddresses/', parameters('publicIPAddressName'))]"
            ],
            "location": "[parameters('location')]",
            "properties": {
                "enableIPForwarding": true,
                "enableAcceleratedNetworking": false,
                "ipConfigurations": [
                    {
                        "name": "ipconfig-untrust-1",
                        "properties": {
                            "privateIPAddress": "[parameters('intPortPrivateIP')]",
                            "privateIPAllocationMethod": "Static",
                            "publicIPAddress": { "id": "[if(equals(parameters('publicIPNewOrExisting'),'new'), resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIPAddressName')), resourceId(parameters('publicIPRGName'), 'Microsoft.Network/publicIPAddresses', parameters('publicIPAddressName')))]" },
                            "subnet": { "id": "[variables('subnet1Ref')]" }
                        }
                    }
                ]
            }
        },
        {
            "name": "[variables('nic2')]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2021-01-01",
            "dependsOn": [ "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]" ],
            "location": "[parameters('location')]",
            "properties": {
                "enableIPForwarding": true,
                "enableAcceleratedNetworking": false,
                "ipConfigurations": [ { "name": "ipconfig-trust-1", "properties": { "privateIPAllocationMethod": "Dynamic", "subnet": { "id": "[variables('subnet2Ref')]" } } } ]
            }
        },
        {
            "name": "[variables('nic3')]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2021-01-01",
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]",
                "[resourceId('Microsoft.Network/publicIPAddresses', 'extraNicPublicIP')]"
            ],
            "location": "[parameters('location')]",
            "properties": {
                "enableIPForwarding": true,
                "enableAcceleratedNetworking": false,
                "ipConfigurations": [
                    {
                        "name": "ipconfig-untrust-2",
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', 'extraNicPublicIP')]" },
                            "subnet": { "id": "[variables('subnet3Ref')]" }
                        }
                    }
                ]
            }
        },
        {
            "name": "[parameters('availabilitySetName')]",
            "type": "Microsoft.Compute/availabilitySets",
            "apiVersion": "2020-12-01",
            "condition": "[not(equals(parameters('availabilitySetName'), 'None'))]",
            "dependsOn": [ "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]" ],
            "location": "[parameters('location')]",
            "properties": {
                "platformFaultDomainCount": "[parameters('availabilitySetPlatformFaultDomainCount')]",
                "platformUpdateDomainCount": "[parameters('availabilitySetPlatformUpdateDomainCount')]"
            },
            "sku": { "name": "aligned" }
        },
        {
            "name": "[variables('vmName')]",
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2020-12-01",
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]",
                "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]",
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nic0'))]",
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nic1'))]",
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nic2'))]",
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nic3'))]",
                "[concat('Microsoft.Compute/availabilitySets/', parameters('availabilitySetName'))]"
            ],
            "location": "[parameters('location')]",
            "plan": { "name": "[variables('imageSku')]", "product": "[variables('imageOffer')]", "publisher": "[variables('imagePublisher')]" },
            "properties": {
                "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
                "storageProfile": {
                    "imageReference": { "publisher": "[variables('imagePublisher')]", "offer": "[variables('imageOffer')]", "sku": "[variables('imageSku')]", "version": "[parameters('imageVersion')]" },
                    "osDisk": { "createOption": "FromImage" }
                },
                "networkProfile": {
                    "networkInterfaces": [
                        { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nic0'))]", "properties": { "primary": true } },
                        { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nic1'))]", "properties": { "primary": false } },
                        { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nic2'))]", "properties": { "primary": false } },
                        { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nic3'))]", "properties": { "primary": false } }
                    ]
                },
                "osProfile": {
                    "computerName": "[variables('vmName')]",
                    "adminUsername": "[parameters('adminUser')]",
                    "adminPassword": "[parameters('adminPass')]",
                    "linuxConfiguration": { "disablePasswordAuthentication": false },
                    "customData": "[if(equals(parameters('bootstrap'), 'no'), json('null'), variables('customData'))]"
                },
                "availabilitySet": "[if(equals(parameters('availabilitySetName'), 'None'), json('null'), variables('availabilitySet'))]"
            },
            "zones": "[if(equals(parameters('zone'), 'None'), json('null'), variables('zones'))]"
        }
    ]
}